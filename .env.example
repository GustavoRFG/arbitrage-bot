# =============================================================================
# Arbitrage-Bot — Phase 1 Market Inefficiency Observatory
# =============================================================================
# Phase 1 is READ-ONLY: no API keys are needed. The values below are public
# market-data endpoints and observation thresholds. Do NOT put trading keys
# here.

# ---- Persistence -----------------------------------------------------------
DB_PATH=data/market_inefficiency_observatory.sqlite
LOG_LEVEL=info
LOG_PRETTY=true

# ---- CEX Arbitrage Observatory --------------------------------------------
CEX_ENABLED=true
CEX_EXCHANGES=binance,gateio,kucoin
CEX_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,BNB/USDT,AVAX/USDT,ADA/USDT
CEX_SCAN_INTERVAL_MS=1000
CEX_MAX_BOOK_STALENESS_MS=2000
CEX_ORDER_BOOK_DEPTH_LEVELS=20
CEX_TARGET_NOTIONALS=50,100,250,500,1000
CEX_MIN_GROSS_SPREAD_PCT=0.00
CEX_MIN_APPROX_NET_SPREAD_PCT=0.00
CEX_MIN_EXECUTABLE_NET_SPREAD_PCT=0.00
CEX_MIN_NET_PROFIT_QUOTE=0.00
CEX_OPPORTUNITY_CLOSE_GRACE_MS=1500
CEX_PERSIST_BOOK_SNAPSHOTS=opportunities_only

# Per-exchange taker fee overrides (decimal: 0.001 = 0.1%). If unset, conservative defaults apply.
CEX_FEE_BINANCE_TAKER=0.001
CEX_FEE_GATEIO_TAKER=0.002
CEX_FEE_KUCOIN_TAKER=0.001
CEX_FEE_MEXC_TAKER=0.0008

# ---- Polymarket Repricing Lag Observatory (skeleton) ----------------------
POLYMARKET_ENABLED=false
POLYMARKET_ASSETS=BTC
POLYMARKET_HORIZONS=5m
POLYMARKET_SCAN_ACTIVE_MARKETS=true
POLYMARKET_SCAN_INTERVAL_MS=500
POLYMARKET_MAX_BOOK_STALENESS_MS=1500
POLYMARKET_TOP_BOOK_DEPTH_LEVELS=20
POLYMARKET_TRACK_BINANCE_FEED=true
POLYMARKET_TRACK_CHAINLINK_FEED=false
POLYMARKET_REFERENCE_MOVE_THRESHOLD_PCT=0.05
POLYMARKET_LATE_WINDOW_THRESHOLD_MS=30000
POLYMARKET_DISTANCE_FROM_OPEN_THRESHOLD_PCT=0.03
POLYMARKET_REPRICING_CLOSE_GRACE_MS=1500
POLYMARKET_STORE_RAW_BOOKS=false
POLYMARKET_STORE_FEATURE_SNAPSHOTS=true

# Polymarket public endpoints (defaults are the official public ones)
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
